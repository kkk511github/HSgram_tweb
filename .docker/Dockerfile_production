# Base image
FROM node:22-alpine AS builder

# Set the working directory in the container
WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm run build

# pull nginx as webserver and load balancer
FROM nginx:stable-alpine3.20-slim

RUN apk update && apk upgrade --no-cache

# Copy static runtime files first, then the fresh build output over them.
COPY ./public /usr/share/nginx/html
COPY ./deploy/nginx.hsgram.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
